# ============================================================
# VARIABLES D'ENVIRONNEMENT — AstraScan
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# Anthropic API — OBLIGATOIRE pour l'analyse d'images
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Safe Browsing API (optionnel)
# https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=your_key_here

# VirusTotal API (optionnel)
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_key_here

# WHOIS XML API (optionnel)
# https://whoisxmlapi.com/
WHOIS_API_KEY=your_key_here
